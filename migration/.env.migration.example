# =========================================================================
# MIGRATION CONFIG — copy this to .env.migration and fill in real values
# =========================================================================
# .env.migration is gitignored. This .example file IS committed.
# =========================================================================

# --- Hetzner (destination) ---
HETZNER_IP="88.99.167.49"
HETZNER_IPV6="2a01:4f8:10a:3759::2"
HETZNER_USER="deploy"
HETZNER_HOSTNAME="careai-hetzner"

# --- Vultr (source, keep running until we've verified Hetzner works) ---
VULTR_IP="45.32.177.231"
VULTR_USER="deploy"

# --- Local SSH keys on this Mac ---
# Private key used to SSH into BOTH servers (same key, two authorized_keys)
LOCAL_SSH_KEY="$HOME/.ssh/careai_deploy"
LOCAL_PUB_KEY="$HOME/.ssh/careai_deploy.pub"

# --- Remote paths ---
# Keep same path on Hetzner so compose files Just Work
REMOTE_CAREAI_DIR="/home/deploy/careai"
REMOTE_NVME_DIR="/mnt/nvme_data"

# --- GHCR (GitHub Container Registry) ---
GHCR_USER="pravreddy"
# Token is read from prompt at runtime — NEVER commit here
# Scope needed: read:packages

# --- Postgres ---
# Will be auto-generated fresh during phase 5. Leave blank.
NEW_POSTGRES_PASSWORD=""

# --- Domains (for verification steps) ---
SIGNSIMPLE_DOMAIN="signsimple.co.uk"
CAREAI_DOMAIN="careaisoftware.co.uk"

# --- Logging / state ---
LOG_DIR="$(dirname "${BASH_SOURCE[0]}")/state"
